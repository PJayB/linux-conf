# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        colors = true
        interval = 5
}

#order += "ipv6"
order += "wireless _first_"
order += "ethernet _first_"
order += "battery all"
order += "disk /"
order += "disk /home"
order += "cpu_usage"
order += "memory"
#order += "load"
order += "tztime local"
order += "volume master"

wireless _first_ {
        format_up = "🌐 WiFi (%quality at %essid) %ip"
        format_down = "🌐 WiFi down"
}

ethernet _first_ {
        # if you use %speed, i3status requires root privileges
        format_up = "🌐 Eth. %ip (%speed)"
        format_down = "🌐 down"
}

battery all {
        format = "%status %percentage %remaining"
        format = "🔋 %status %percentage %remaining"
}

tztime local {
        format = "🗓 %Y-%m-%d %H:%M:%S"
}

cpu_usage {
    format = "🤖 %usage"
}

memory {
    format = "🐏 %available"
}

#load {
#        format = "load %1min %5min %15min"
#}

disk "/" {
        format = "🐧 %avail"
}

disk "/home" {
        format = "🏠 %avail"
}

load {
        format = "%1min"
}

volume master {
        format = "🔈 %volume"
        format_muted = "🔇 muted (%volume)"
        device = "pulse:alsa_output.usb-Bose_Corporation_Bose_USB_Audio-00.analog-surround-21"
}

general {
  output_format = "i3bar"
  colors = true
  color_good = "#00FF00"
  color_degraded = "#FFFF00"
  color_bad = "#FF0000"
}

