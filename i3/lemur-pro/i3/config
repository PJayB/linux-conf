#client.focused          #333333 #222222 #FFFFFF #292D2E   #222222
#client.focused_inactive #333333 #222222 #888888 #292D2E   #222222
client.unfocused        #333333 #222222 #888888 #292D2E   #222222
client.urgent           #2F343A #900000 #FFFFFF #900000   #900000
client.placeholder      #000000 #0C0C0C #FFFFFF #000000   #0C0C0C

client.background       #FFFFFF

bar {
  status_command ~/.config/i3status/i3-status.sh
  i3bar_command i3bar --transparency
  colors {
    background #00000000
    statusline #FFFFFF
    separator  #666666

    # purple
    focused_workspace  #6000EE #5800C8 #FFFFFF
    active_workspace   #333333 #222222 #FFFFFF
    inactive_workspace #333333 #222222 #888888
    urgent_workspace   #2F343A #D00052 #FFFFFF
    binding_mode       #2F343A #D00052 #FFFFFF

    # orange
    focused_workspace  #715335 #D0A800 #000000
    active_workspace   #333333 #222222 #FFFFFF
    inactive_workspace #333333 #222222 #888888
    urgent_workspace   #2F343A #FF0650 #FFFFFF
    binding_mode       #2F343A #FF0650 #FFFFFF
  }
}

