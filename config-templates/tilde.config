highlight_attributes {
	normal = (  )
}
config_version = 1
%terminals {
	name = "xterm-256color"
	key_timeout = -1000
	highlight_attributes {
		normal = (  )
	}
}
%terminals {
	name = "screen"
	key_timeout = -1000
	highlight_attributes {
		normal = (  )
	}
}
color = true
attributes {
	text = ( "fg white", "bg 235" )
}
wrap = false
tab_spaces = true
auto_indent = true
indent_aware_home = true
show_tabs = false
strip_spaces = false
tabsize = 4
